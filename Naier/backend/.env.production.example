MESH_SERVER_HOST=0.0.0.0
MESH_SERVER_PORT=8080
MESH_SERVER_MODE=release
MESH_SERVER_ALLOWED_ORIGINS=https://app.example.com

MESH_DATABASE_POSTGRES_DSN=postgres://mesh:<password>@postgres.internal:5432/naier?sslmode=disable
MESH_DATABASE_REDIS_ADDR=redis.internal:6379
MESH_DATABASE_REDIS_PASSWORD=<redis-password>

MESH_AUTH_JWT_SECRET=<jwt-secret>
MESH_AUTH_JWT_EXPIRY=15m
MESH_AUTH_REFRESH_EXPIRY=720h

MESH_MEDIA_MINIO_ENDPOINT=minio.internal:9000
MESH_MEDIA_MINIO_BUCKET=naier
MESH_MEDIA_MINIO_ACCESS_KEY=<minio-access-key>
MESH_MEDIA_MINIO_SECRET_KEY=<minio-secret-key>

MESH_FEDERATION_SERVER_DOMAIN=api.example.com
MESH_FEDERATION_SERVER_PUBLIC_KEY=<base64-public-key>
MESH_FEDERATION_SERVER_PRIVATE_KEY=<base64-private-key>

MESH_BETA_INVITE_ONLY=true
MESH_ADMIN_API_TOKEN=<admin-api-token>
